# ──────────────────────────────────────────────────────────────
# PROJECT · v4l3rio.github.io
# ──────────────────────────────────────────────────────────────
# Portfolio personale hostato su GitHub Pages. Sito statico
# HTML/CSS/JS con configurazione Jekyll (usata da GitHub Pages
# per il build automatico).
#
# Stack:  HTML5, CSS3, JavaScript vanilla, Jekyll (GitHub Pages)
# Deploy: push su main → GitHub Pages fa il build automaticamente
# Local:  bundle exec jekyll serve  (richiede Ruby + Bundler)
#         oppure apri index.html direttamente nel browser
# Nota:   il repo deve chiamarsi v4l3rio.github.io su GitHub
# ──────────────────────────────────────────────────────────────

# Jekyll build output (generato da GitHub Pages, non va in repo)
_site/
.jekyll-cache/
.jekyll-metadata

# Ruby / Bundler
.bundle/
vendor/bundle/
Gemfile.lock

# macOS
.DS_Store

# Editor
.vscode/
.idea/
